# Python
__pycache__/
*.pyc
*.pyo
*.pyd
venv/
.venv/
.env
*.egg-info/

# BioGears engine binaries (too large for git — transfer via scp)
biogears_service/engine/

# Patient engine state files (personal health data — NEVER commit)
clinical_data/states/
clinical_data/history/
user_states/
user_history/

# Simulation runtime output
biogears_service/runtime/
biogears_service/simulation_results/
biogears_service/__pycache__/

# Generated health reports
reports/

# Logs
logs/
*.log
server_log.txt

# Runtime databases / job stores
twins_database.db
twins_database.json
biogears_service/jobs_store.json

# Server backups
backups/

# Scenarios generated at runtime by BioGears
Scenarios/

# Test / scratch XML artifacts
test_*.xml
debug_*.xml

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/

# Large archives
*.zip
*.tar.gz
*.rar

# Test artifacts
test_*.py
debug_*.py

# VitalHealth secrets — never commit
VitalHealth/.env
VitalHealth/.env.local

# Healthbot — LLM GGUF weight files are too large for git (each ~3 GB)
# Download separately from HuggingFace and place in healthbot/model/
healthbot/model/*.gguf
healthbot/__pycache__/
healthbot/**/__pycache__/
healthbot/*.pyc
